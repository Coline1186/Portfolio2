{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "ts-node-dev --exit-child --watch src --poll src/index.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "m:g": "npm run typeorm -- -d src/datasource/datasource.ts migration:generate src/migrations/Init",
    "m:r": "npm run typeorm -- -d src/datasource/datasource.ts migration:run",
    "m:revert": "npm run typeorm -- -d src/datasource/datasource.ts migration:revert",
    "test": "jest --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Backend for the portfolio project",
  "dependencies": {
    "@apollo/server": "^4.12.2",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/mock": "^9.1.5",
    "@graphql-tools/schema": "^10.0.23",
    "@types/cookies": "^0.9.2",
    "argon2": "^0.44.0",
    "class-validator": "^0.14.3",
    "cookies": "^0.9.1",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "graphql-tag": "^2.12.6",
    "jest": "^30.2.0",
    "jose": "^6.1.3",
    "module-alias": "^2.3.4",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/cookies": "^0.9.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.17.43",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.9",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "_moduleAliases": {
    "@": "./src"
  }
}
